global:
  smtp_smarthost: "smtp.example.com:587"
  smtp_from: "alerts@example.com"
  smtp_auth_username: "alerts@example.com"
  smtp_auth_password: "REPLACE_WITH_APP_PASSWORD"
  smtp_require_tls: true

route:
  receiver: "email"
  group_by: ["alertname"]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 3h

receivers:
  - name: "email"
    email_configs:
      - to: "you@example.com"
        send_resolved: true
